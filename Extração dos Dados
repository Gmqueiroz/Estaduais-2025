        "          # Col 9: Appearances\n",
        "          # Col 10: Goals\n",
        "          # Col 11: Assists\n",
        "          # Col 18: Minutes played\n",
        "\n",
        "          in_squad <- if(length(cells) >= 8) extract_number(cells[8]) else 0\n",
        "          appearances <- if(length(cells) >= 9) extract_number(cells[9]) else 0\n",
        "          goals <- if(length(cells) >= 10) extract_number(cells[10]) else 0\n",
        "          assists <- if(length(cells) >= 11) extract_number(cells[11]) else 0\n",
        "\n",
        "          # Minutes played - look in col 18 first (has apostrophe format)\n",
        "          minutes_played <- NA_real_\n",
        "          if(length(cells) >= 18) {\n",
        "            minutes_text <- cells[18] %>% rvest::html_text() %>% stringr::str_squish()\n",
        "            if(!is.na(minutes_text) && minutes_text != \"\" && minutes_text != \"-\") {\n",
        "              minutes_clean <- minutes_text %>%\n",
        "                gsub(\"\\\\.\", \"\", .) %>%\n",
        "                gsub(\"'\", \"\", .) %>%\n",
        "                gsub(\",\", \"\", .)\n",
        "              minutes_num <- suppressWarnings(as.numeric(minutes_clean))\n",
        "              if(!is.na(minutes_num) && minutes_num > 0) {\n",
        "                minutes_played <- minutes_num\n",
        "              }\n",
        "            }\n",
        "          }\n",
        "\n",
        "          # If no minutes in col 18, try col 17\n",
        "          if(is.na(minutes_played) && length(cells) >= 17) {\n",
        "            minutes_text <- cells[17] %>% rvest::html_text() %>% stringr::str_squish()\n",
        "            if(!is.na(minutes_text) && minutes_text != \"\" && minutes_text != \"-\") {\n",
        "              # Skip if it looks like PPG (decimal between 0-3)\n",
        "              minutes_num <- suppressWarnings(as.numeric(minutes_text))\n",
        "              if(!is.na(minutes_num) && (minutes_num > 3 || minutes_num < 0.5)) {\n",
        "                minutes_clean <- minutes_text %>%\n",
        "                  gsub(\"\\\\.\", \"\", .) %>%\n",
        "                  gsub(\"'\", \"\", .)\n",
        "                minutes_num <- suppressWarnings(as.numeric(minutes_clean))\n",
        "                if(!is.na(minutes_num) && minutes_num > 0) {\n",
        "                  minutes_played <- minutes_num\n",
        "                }\n",
        "              }\n",
        "            }\n",
        "          }\n",
        "\n",
        "          player_data_list[[i]] <- data.frame(\n",
        "            team_name = team_name,\n",
        "            league = league,\n",
        "            country = country,\n",
        "            player_name = player_name,\n",
        "            player_url = player_url,\n",
        "            player_pos = player_pos,\n",
        "            player_age = player_age,\n",
        "            nationality = nationality,\n",
        "            in_squad = in_squad,\n",
        "            appearances = appearances,\n",
        "            goals = goals,\n",
        "            assists = assists,\n",
        "            minutes_played = minutes_played,\n",
        "            stringsAsFactors = FALSE\n",
        "          )\n",
        "        }\n",
        "      }\n",
        "\n",
        "      # Combine all player data\n",
        "      if(length(player_data_list) > 0) {\n",
        "        team_data_df <- dplyr::bind_rows(player_data_list)\n",
        "\n",
        "        # Remove duplicate rows\n",
        "        if(\"player_url\" %in% names(team_data_df) && !all(is.na(team_data_df$player_url))) {\n",
        "          team_data_df <- team_data_df %>%\n",
        "            dplyr::distinct(player_url, .keep_all = TRUE)\n",
        "        }\n",
        "      } else {\n",
        "        team_data_df <- data.frame()\n",
        "      }\n",
        "\n",
        "    } else {\n",
        "      team_data_df <- data.frame()\n",
        "    }\n",
        "\n",
        "    return(team_data_df)\n",
        "\n",
        "  }\n",
        "\n",
        "  # create the progress bar with a progress function.\n",
        "  pb <- progress::progress_bar$new(total = length(team_url))\n",
        "\n",
        "  f_possibly <- purrr::possibly(each_squad_stats, otherwise = data.frame(), quiet = FALSE)\n",
        "  purrr::map_dfr(\n",
        "    team_url,\n",
        "    f_possibly\n",
        "  )\n",
        "\n",
        "}"
      ]
    },

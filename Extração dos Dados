        "# First, install all required packages if you haven't already\n",
        "install.packages(c(\"magrittr\", \"rvest\", \"xml2\", \"stringr\", \"dplyr\", \"purrr\", \"progress\"))\n",
        "\n",
        "# Then load all libraries\n",
        "library(magrittr)\n",
        "library(rvest)\n",
        "library(xml2)\n",
        "library(stringr)\n",
        "library(dplyr)\n",
        "library(purrr)\n",
        "library(progress)\n",
        "\n",
        "# Now run the function\n",
        "tm_squad_stats_detailed <- function(team_url) {\n",
        "\n",
        "  main_url <- \"https://www.transfermarkt.com\"\n",
        "\n",
        "  # Function to extract nationality from player page\n",
        "  extract_nationality <- function(player_url) {\n",
        "    if(is.na(player_url) || player_url == \"\") return(NA_character_)\n",
        "\n",
        "    player_page <- tryCatch(xml2::read_html(player_url), error = function(e) NA)\n",
        "\n",
        "    if(!is.na(player_page)) {\n",
        "      # Look for the flag image in the player header\n",
        "      flag_img <- player_page %>%\n",
        "        rvest::html_nodes(\".data-header__items img\") %>%\n",
        "        .[1]\n",
        "\n",
        "      if(length(flag_img) > 0) {\n",
        "        nationality <- flag_img %>% rvest::html_attr(\"title\")\n",
        "        if(is.na(nationality) || nationality == \"\") {\n",
        "          nationality <- flag_img %>% rvest::html_attr(\"alt\")\n",
        "        }\n",
        "        if(!is.na(nationality) && nationality != \"\") return(nationality)\n",
        "      }\n",
        "\n",
        "      # Look for the citizenship text in the info row\n",
        "      citizenship_text <- player_page %>%\n",
        "        rvest::html_nodes(\".data-header__info-item\") %>%\n",
        "        rvest::html_text()\n",
        "\n",
        "      if(length(citizenship_text) > 0) {\n",
        "        citizenship_line <- grep(\"Citizenship:\", citizenship_text, value = TRUE, ignore.case = TRUE)\n",
        "        if(length(citizenship_line) > 0) {\n",
        "          nationality <- stringr::str_extract(citizenship_line, \"Citizenship:\\\\s*([A-Za-zÀ-ÿ\\\\s]+)\") %>%\n",
        "            stringr::str_replace(\"Citizenship:\\\\s*\", \"\") %>%\n",
        "            stringr::str_squish()\n",
        "          if(!is.na(nationality) && nationality != \"\") return(nationality)\n",
        "        }\n",
        "      }\n",
        "\n",
        "      # Look for the nationality in the info table\n",
        "      info_table <- player_page %>%\n",
        "        rvest::html_nodes(\".info-table\")\n",
        "\n",
        "      if(length(info_table) > 0) {\n",
        "        rows <- info_table %>% rvest::html_nodes(\"tr\")\n",
        "        for(row in rows) {\n",
        "          header <- row %>% rvest::html_nodes(\"th\") %>% rvest::html_text()\n",
        "          if(length(header) > 0 && grepl(\"Citizenship|Nationality\", header, ignore.case = TRUE)) {\n",
        "            value <- row %>% rvest::html_nodes(\"td\") %>% rvest::html_text() %>% stringr::str_squish()\n",
        "            if(length(value) > 0 && value != \"\") {\n",
        "              return(value)\n",
        "            }\n",
        "          }\n",
        "        }\n",
        "      }\n",
        "    }\n",
        "\n",
        "    return(NA_character_)\n",
        "  }\n",
        "\n",
        "  each_squad_stats <- function(each_team_url) {\n",
        "    pb$tick()\n",
        "\n",
        "    # Convert startseite URL to leistungsdaten URL\n",
        "    team_data_url <- gsub(\"startseite\", \"leistungsdaten\", each_team_url)\n",
        "    # Add /plus/1 to get detailed view with more columns\n",
        "    if(!grepl(\"plus/\", team_data_url)) {\n",
        "      team_data_url <- paste0(team_data_url, \"/plus/1\")\n",
        "    }\n",
        "\n",
        "    team_data_page <- tryCatch(xml2::read_html(team_data_url), error = function(e) NA)\n",
        "\n",
        "    if(!is.na(team_data_page)) {\n",
        "\n",
        "      # Get team info\n",
        "      team_name <- team_data_page %>%\n",
        "        rvest::html_nodes(\".data-header__headline-wrapper--oswald\") %>%\n",
        "        rvest::html_text() %>%\n",
        "        stringr::str_squish()\n",
        "      if(length(team_name) == 0) team_name <- NA_character_\n",
        "\n",
        "      # League - handle empty case\n",
        "      league <- team_data_page %>%\n",
        "        rvest::html_nodes(\".data-header__club a\") %>%\n",
        "        rvest::html_text() %>%\n",
        "        stringr::str_squish()\n",
        "      if(length(league) == 0) league <- NA_character_\n",
        "\n",
        "      country <- team_data_page %>%\n",
        "        rvest::html_nodes(\".vm\") %>%\n",
        "        rvest::html_attr(\"title\")\n",
        "      if(length(country) == 0) country <- NA_character_\n",
        "\n",
        "      # Get all data rows\n",
        "      data_rows <- team_data_page %>%\n",
        "        rvest::html_nodes(\"#yw1 .items tbody tr.odd, #yw1 .items tbody tr.even\")\n",
        "\n",
        "      if(length(data_rows) == 0) {\n",
        "        data_rows <- team_data_page %>%\n",
        "          rvest::html_nodes(\"table.items tbody tr\")\n",
        "      }\n",
        "\n",
        "      if(length(data_rows) == 0) {\n",
        "        return(data.frame())\n",
        "      }\n",
        "\n",
        "      # Extract data from each row\n",
        "      player_data_list <- list()\n",
        "\n",
        "      for(i in seq_along(data_rows)) {\n",
        "        row <- data_rows[i]\n",
        "\n",
        "        # Get all cells in this row\n",
        "        cells <- row %>% rvest::html_nodes(\"td\")\n",
        "\n",
        "        if(length(cells) >= 12) {\n",
        "\n",
        "          # Helper function to clean text\n",
        "          clean_text <- function(text) {\n",
        "            if(length(text) == 0) return(NA_character_)\n",
        "            text <- text %>% stringr::str_squish()\n",
        "            if(text == \"\" || text == \"-\") return(NA_character_)\n",
        "            return(text)\n",
        "          }\n",
        "\n",
        "          # Helper function to extract numeric value\n",
        "          extract_number <- function(cell, default = 0) {\n",
        "            if(length(cell) == 0) return(default)\n",
        "            text <- cell %>% rvest::html_text() %>% stringr::str_squish()\n",
        "            if(length(text) == 0 || is.na(text) || text == \"\" || text == \"-\") return(default)\n",
        "            # Handle special text values\n",
        "            if(grepl(\"Not in squad|Not used\", text)) return(0)\n",
        "            # Remove non-numeric characters except decimal\n",
        "            num_text <- stringr::str_extract(text, \"\\\\d+\\\\.?\\\\d*\")\n",
        "            if(is.na(num_text)) return(default)\n",
        "            result <- suppressWarnings(as.numeric(num_text))\n",
        "            if(is.na(result)) return(default)\n",
        "            return(result)\n",
        "          }\n",
        "\n",
        "          # Extract player name and URL from the second cell (column 2)\n",
        "          player_name <- NA_character_\n",
        "          player_url <- NA_character_\n",
        "\n",
        "          if(length(cells) >= 2) {\n",
        "            # Look for the player profile link in column 2\n",
        "            player_link <- cells[2] %>% rvest::html_nodes(\"a[href*='/profil/spieler/']\")\n",
        "            if(length(player_link) > 0) {\n",
        "              # Get the first valid player link\n",
        "              for(link in player_link) {\n",
        "                href <- link %>% rvest::html_attr(\"href\")\n",
        "                if(!is.null(href) && grepl(\"/profil/spieler/\", href)) {\n",
        "                  player_url <- paste0(main_url, href)\n",
        "                  player_name <- link %>% rvest::html_text() %>% stringr::str_squish()\n",
        "                  if(!is.na(player_name) && player_name != \"\") {\n",
        "                    break\n",
        "                  }\n",
        "                }\n",
        "              }\n",
        "            }\n",
        "          }\n",
        "\n",
        "          # Skip if no player name\n",
        "          if(is.na(player_name) || player_name == \"\" || nchar(player_name) < 2) next\n",
        "\n",
        "          # Extract position from column 5\n",
        "          player_pos <- NA_character_\n",
        "          if(length(cells) >= 5) {\n",
        "            player_pos <- clean_text(cells[5] %>% rvest::html_text())\n",
        "          }\n",
        "\n",
        "          # Extract age from column 6\n",
        "          player_age <- NA_real_\n",
        "          if(length(cells) >= 6) {\n",
        "            player_age <- extract_number(cells[6])\n",
        "            if(player_age == 0) player_age <- NA_real_\n",
        "          }\n",
        "\n",
        "          # Extract nationality from the player's profile page\n",
        "          nationality <- extract_nationality(player_url)\n",
        "\n",
        "          # Extract stats based on column mapping from debug:\n",
        "          # Col 8: In squad\n",
        "          # Col 9: Appearances\n",
        "          # Col 10: Goals\n",
        "          # Col 11: Assists\n",
        "          # Col 12: Yellow cards\n",
        "          # Col 13: Second yellow cards\n",
        "          # Col 14: Red cards\n",
        "          # Col 15: Substitutions on\n",
        "          # Col 16: Substitutions off\n",
        "          # Col 18: Minutes played\n",
        "\n",
        "          in_squad <- if(length(cells) >= 8) extract_number(cells[8]) else 0\n",
        "          appearances <- if(length(cells) >= 9) extract_number(cells[9]) else 0\n",
        "          goals <- if(length(cells) >= 10) extract_number(cells[10]) else 0\n",
        "          assists <- if(length(cells) >= 11) extract_number(cells[11]) else 0\n",
        "          yellow_cards <- if(length(cells) >= 12) extract_number(cells[12]) else 0\n",
        "          second_yellow_cards <- if(length(cells) >= 13) extract_number(cells[13]) else 0\n",
        "          red_cards <- if(length(cells) >= 14) extract_number(cells[14]) else 0\n",
        "          subs_on <- if(length(cells) >= 15) extract_number(cells[15]) else 0\n",
        "          subs_off <- if(length(cells) >= 16) extract_number(cells[16]) else 0\n",
        "\n",
        "          # Minutes played - look in col 18 first (has apostrophe format)\n",
        "          minutes_played <- NA_real_\n",
        "          if(length(cells) >= 18) {\n",
        "            minutes_text <- cells[18] %>% rvest::html_text() %>% stringr::str_squish()\n",
        "            if(!is.na(minutes_text) && minutes_text != \"\" && minutes_text != \"-\") {\n",
        "              minutes_clean <- minutes_text %>%\n",
        "                gsub(\"\\\\.\", \"\", .) %>%\n",
        "                gsub(\"'\", \"\", .) %>%\n",
        "                gsub(\",\", \"\", .)\n",
        "              minutes_num <- suppressWarnings(as.numeric(minutes_clean))\n",
        "              if(!is.na(minutes_num) && minutes_num > 0) {\n",
        "                minutes_played <- minutes_num\n",
        "              }\n",
        "            }\n",
        "          }\n",
        "\n",
        "          # If no minutes in col 18, try col 17\n",
        "          if(is.na(minutes_played) && length(cells) >= 17) {\n",
        "            minutes_text <- cells[17] %>% rvest::html_text() %>% stringr::str_squish()\n",
        "            if(!is.na(minutes_text) && minutes_text != \"\" && minutes_text != \"-\") {\n",
        "              # Skip if it looks like PPG (decimal between 0-3)\n",
        "              minutes_num <- suppressWarnings(as.numeric(minutes_text))\n",
        "              if(!is.na(minutes_num) && (minutes_num > 3 || minutes_num < 0.5)) {\n",
        "                minutes_clean <- minutes_text %>%\n",
        "                  gsub(\"\\\\.\", \"\", .) %>%\n",
        "                  gsub(\"'\", \"\", .)\n",
        "                minutes_num <- suppressWarnings(as.numeric(minutes_clean))\n",
        "                if(!is.na(minutes_num) && minutes_num > 0) {\n",
        "                  minutes_played <- minutes_num\n",
        "                }\n",
        "              }\n",
        "            }\n",
        "          }\n",
        "\n",
        "          player_data_list[[i]] <- data.frame(\n",
        "            team_name = team_name,\n",
        "            league = league,\n",
        "            country = country,\n",
        "            player_name = player_name,\n",
        "            player_url = player_url,\n",
        "            player_pos = player_pos,\n",
        "            player_age = player_age,\n",
        "            nationality = nationality,\n",
        "            in_squad = in_squad,\n",
        "            appearances = appearances,\n",
        "            goals = goals,\n",
        "            assists = assists,\n",
        "            yellow_cards = yellow_cards,\n",
        "            second_yellow_cards = second_yellow_cards,\n",
        "            red_cards = red_cards,\n",
        "            substitutions_on = subs_on,\n",
        "            substitutions_off = subs_off,\n",
        "            minutes_played = minutes_played,\n",
        "            stringsAsFactors = FALSE\n",
        "          )\n",
        "        }\n",
        "      }\n",
        "\n",
        "      # Combine all player data\n",
        "      if(length(player_data_list) > 0) {\n",
        "        team_data_df <- dplyr::bind_rows(player_data_list)\n",
        "\n",
        "        # Remove duplicate rows\n",
        "        if(\"player_url\" %in% names(team_data_df) && !all(is.na(team_data_df$player_url))) {\n",
        "          team_data_df <- team_data_df %>%\n",
        "            dplyr::distinct(player_url, .keep_all = TRUE)\n",
        "        }\n",
        "      } else {\n",
        "        team_data_df <- data.frame()\n",
        "      }\n",
        "\n",
        "    } else {\n",
        "      team_data_df <- data.frame()\n",
        "    }\n",
        "\n",
        "    return(team_data_df)\n",
        "\n",
        "  }\n",
        "\n",
        "  # Create progress bar\n",
        "  pb <- progress::progress_bar$new(total = length(team_url))\n",
        "\n",
        "  # Handle both single URL and vector of URLs\n",
        "  f_possibly <- purrr::possibly(each_squad_stats, otherwise = data.frame(), quiet = FALSE)\n",
        "\n",
        "  result <- purrr::map_dfr(\n",
        "    team_url,\n",
        "    f_possibly\n",
        "  )\n",
        "\n",
        "  return(result)\n",
        "\n",
        "}\n",
        "\n",
        "# Test with Palmeiras URL\n",
        "palmeiras_url <- \"https://www.transfermarkt.com/sociedade-esportiva-palmeiras/startseite/verein/1023\"\n",
        "result <- tm_squad_stats_detailed(palmeiras_url)\n",
        "\n",
        "# View the result\n",
        "View(result)\n",
        "\n",
        "# Test with multiple URLs\n",
        "team_urls <- c(\n",
        "  \"https://www.transfermarkt.com/sociedade-esportiva-palmeiras/startseite/verein/1023\",\n",
        "  \"https://www.transfermarkt.com/associacao-chapecoense-de-futebol/startseite/verein/17776\"\n",
        ")\n",
        "\n",
        "result_multiple <- tm_squad_stats_detailed(team_urls)"
      ]
    },
